# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/repo_sync?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# GitHub Configuration (Optional in .env - Can be set via UI instead)
# The variables below are only used as fallback defaults. You can configure them
# dynamically via the Admin Settings page in the web UI, which saves them encrypted in the database.
#
# GITHUB_APP_ID=""
# GITHUB_APP_SLUG=""
# GITHUB_APP_PRIVATE_KEY=""
# GITHUB_WEBHOOK_SECRET=""
#
# GITHUB_OAUTH_CLIENT_ID=""
# GITHUB_OAUTH_CLIENT_SECRET=""
# GITHUB_OAUTH_CALLBACK_URL="http://localhost:3001/auth/github/callback"


# Server
API_PORT=3001
API_URL="http://localhost:3001"
WEB_URL="http://localhost:5173"

# Encryption key for storing GitHub tokens
ENCRYPTION_KEY="change-me-32-byte-hex-key-here!!"
